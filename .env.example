# CRM Automation Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# Google Gemini API (for lead scoring + email writing)
# Get free API key at: https://aistudio.google.com
# ============================================
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# Airtable (CRM database)
# ============================================
AIRTABLE_API_KEY=your_airtable_personal_access_token_here
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# ============================================
# Gmail OAuth (for notifications + follow-up emails)
# ============================================
GMAIL_CLIENT_ID=your_gmail_client_id_here.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REFRESH_TOKEN=

# ============================================
# Twilio (WhatsApp/SMS follow-up)
# ============================================
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=+14155238886

# ============================================
# Business Owner Contact
# ============================================
OWNER_EMAIL=your@email.com
OWNER_WHATSAPP=+1234567890

# ============================================
# Business Configuration
# ============================================
BUSINESS_NAME=Your Business Name

# ============================================
# Lead Scoring Thresholds
# ============================================
LEAD_SCORE_HOT_THRESHOLD=8
LEAD_SCORE_WARM_THRESHOLD=5
